{
  "id": "fb-w8-pull-morning-flow",
  "name": "W8 Pull Morning Flow",
  "description": "12 min. Same as W7. Spine primer (cat-cow, dead hang 25s, scap pull-ups x10) + shoulder/arm prep + hip opener.",
  "routineId": "functional-bulk",
  "tags": ["floor", "mobility", "back", "biceps", "morning", "bodyweight", "fixed"],
  "estimatedDuration": 12,
  "equipment": ["bodyweight", "mat", "pull-up-bar"],
  "difficulty": "beginner",
  "sets": [
    {
      "id": "spine-primer",
      "name": "Spine + Scap Primer",
      "type": "exercises",
      "rounds": 1,
      "exercises": [
        { "id": "cat-cow", "reps": 10, "notes": "Full spinal wave. Slow." },
        { "id": "dead-hang", "duration": 25, "notes": "25s. Decompress shoulders, warm grip." },
        { "id": "scapular-pull-up", "reps": 10, "notes": "No elbow bend -- just scapulae retracting. Should be crisp by W8." }
      ],
      "restBetween": 0,
      "restAfter": 15
    },
    {
      "id": "shoulder-arm-prep",
      "name": "Shoulder + Arm Prep",
      "type": "exercises",
      "rounds": 1,
      "exercises": [
        { "id": "prone-y-raises", "reps": 8, "notes": "Face down, arms in Y. Lower trap + rotator cuff. Carries over from push day." },
        { "id": "gmb-wrist-prep", "reps": 10, "notes": "Loosen wrists and forearms for grip work." },
        { "id": "arm-circle", "reps": "10 each direction", "notes": "Small to big. Warm bicep insertions." },
        { "id": "doorframe-chest-stretch", "duration": 20, "notes": "Opens bicep and chest. Preacher curl prep." }
      ],
      "restBetween": 0,
      "restAfter": 15
    },
    {
      "id": "hip-opener",
      "name": "Hip + Back Opener",
      "type": "exercises",
      "rounds": 1,
      "exercises": [
        { "id": "happy-baby", "duration": 30, "notes": "Hip opener. Gentle." },
        { "id": "supine-spinal-twist", "duration": 30, "notes": "30s each side. Lower back release." },
        { "id": "child-pose-reach", "duration": 30, "notes": "Walk hands to each side. Lateral lat stretch." }
      ],
      "restBetween": 0,
      "restAfter": 0
    }
  ],
  "tips": [
    "12 min -- same as W7. Dead hang 25s, scap pull-ups x10.",
    "Bicep prep primes preacher curl -- which comes early in the pull session.",
    "If short on time: spine primer + arm prep. 6 min."
  ]
}